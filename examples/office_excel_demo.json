{
  "name": "office_excel_demo",
  "description": "创建销售报告 Excel，包含数据和柱状图",
  "tasks": [
    {"action": "excel_create", "target": null, "value": "examples/output/sales_report.xlsx", "delay": 0.5},
    {"action": "excel_write_cell", "target": "Sheet1!A1", "value": "Product", "delay": 0.2},
    {"action": "excel_write_cell", "target": "Sheet1!B1", "value": "Q1 Sales", "delay": 0.2},
    {"action": "excel_write_cell", "target": "Sheet1!C1", "value": "Q2 Sales", "delay": 0.2},
    {"action": "excel_write_range", "target": "A2", "value": "[[\"Laptop\",120,150],[\"Phone\",300,280],[\"Tablet\",80,95],[\"Watch\",150,200]]", "delay": 0.3},
    {"action": "excel_chart", "target": null, "value": "{\"type\":\"bar\",\"data_range\":\"A1:C5\",\"title\":\"Sales Report H1 2026\",\"position\":\"E2\"}", "delay": 0.5},
    {"action": "excel_save", "target": null, "value": "examples/output/sales_report.xlsx", "delay": 0.5}
  ],
  "max_retries": 1
}