{
  "name": "抖音搜索UP主",
  "description": "在抖音网页版搜索指定UP主并查看视频列表",
  "version": "1.3",
  "author": "OpenClaw",
  "tasks": [
    {
      "action": "browser_launch",
      "value": "chromium",
      "delay": 3.0
    },
    {
      "action": "browser_goto",
      "value": "https://www.douyin.com",
      "delay": 15.0
    },
    {
      "action": "browser_click",
      "target": "input[type='text'], input[placeholder*='搜索'], .search-input",
      "delay": 2.0
    },
    {
      "action": "browser_type",
      "target": "input[type='text'], input[placeholder*='搜索'], .search-input",
      "value": "李子柒",
      "delay": 1.0
    },
    {
      "action": "browser_press",
      "value": "Enter",
      "delay": 8.0
    },
    {
      "action": "browser_scroll",
      "value": "500",
      "delay": 3.0
    },
    {
      "action": "browser_screenshot",
      "value": "douyin_search_result.png",
      "delay": 2.0
    },
    {
      "action": "browser_close",
      "delay": 2.0
    }
  ],
  "max_retries": 1
}
